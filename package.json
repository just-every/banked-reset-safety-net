{
  "name": "banked-reset-net",
  "version": "0.5.2",
  "description": "A cross-platform tray app for tracking and safely using Codex banked resets before they expire.",
  "author": "Banked Reset Safety Net contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/just-every/banked-reset-safety-net.git"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "main": "out/main/index.js",
  "scripts": {
    "prepare:icons": "node scripts/prepare-icons.mjs",
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm typecheck && pnpm test && electron-vite build",
    "dist:mac": "pnpm prepare:icons && pnpm build && electron-builder --mac --universal --publish never",
    "dist:mac:arm64": "pnpm prepare:icons && pnpm build && electron-builder --mac --arm64 --publish never",
    "dist:win": "pnpm prepare:icons && pnpm build && electron-builder --win --publish never",
    "dist:win:x64": "pnpm prepare:icons && pnpm build && electron-builder --win nsis --x64 --publish never",
    "dist:win:arm64": "pnpm prepare:icons && pnpm build && electron-builder --win nsis --arm64 --config.publish.channel=latest-arm64 --publish never",
    "probe": "tsx scripts/probe.ts"
  },
  "dependencies": {
    "cross-spawn": "7.0.6",
    "electron-updater": "6.8.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/cross-spawn": "6.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "sharp": "0.35.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp"
    ]
  },
  "build": {
    "appId": "net.bankedreset.app",
    "productName": "Banked Reset Safety Net",
    "artifactName": "Banked-Reset-Safety-Net-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "just-every",
      "repo": "banked-reset-safety-net",
      "channel": "latest"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "forceCodeSigning": true,
      "hardenedRuntime": true,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
